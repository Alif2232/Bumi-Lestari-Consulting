# ============================================
# 📁 .env.example — Bumi Lestari Consulting
# ============================================
# Salin file ini ke .env dan isi nilainya
# cp .env.example .env
# ============================================

# Database
# Development: SQLite (file:./dev.db)
# Production:  PostgreSQL (ganti provider di schema.prisma)
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-ganti-di-produksi

# Resend (opsional — untuk email notifikasi lead baru)
# Daftar gratis: https://resend.com
RESEND_API_KEY=
RESEND_DOMAIN=bumilestari.co.id
NOTIFICATION_EMAIL=admin@bumilestari.co.id
