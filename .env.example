# ============================================
# 📁 .env.example — Bumi Lestari Consulting
# ============================================
# Salin file ini ke apps/web/.env dan isi nilainya
# cp .env.example apps/web/.env
# ============================================

# ---- Database (PostgreSQL) ----
# Dev: Gunakan Neon (gratis) — https://neon.tech
# Prod: Neon / Supabase / AWS RDS
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ---- NextAuth.js ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-ganti-di-produksi

# ---- Resend (opsional — email notifikasi lead) ----
RESEND_API_KEY=
RESEND_DOMAIN=bumilestari.co.id
NOTIFICATION_EMAIL=admin@bumilestari.co.id
