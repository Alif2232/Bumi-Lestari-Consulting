// ============================================
// 📁 apps/web/prisma/schema.prisma
// ============================================
// Nama       : Prisma Database Schema
// Fungsi     : Mendefinisikan struktur database untuk
//              Bumi Lestari Consulting
// Penjelasan : Schema ini mencakup:
//              - User + Account + Session (untuk NextAuth.js)
//              - Project (portofolio proyek)
//              - Lead (data form kontak)
//              - Testimonial (ulasan klien)
//              Database: SQLite (development) / PostgreSQL (production)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // 👆 Untuk development pakai SQLite (file lokal)
  //    Untuk production, ganti provider ke "postgresql"
  //    dan URL ke connection string PostgreSQL (via prisma.config.ts)
}

// ============================================
// NEXT-AUTH MODELS (wajib untuk auth)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @default("")
  access_token      String? @default("")
  expires_at        Int?
  token_type        String? @default("")
  scope             String? @default("")
  id_token          String? @default("")
  session_state     String? @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// USER — admin & investor
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  // 👆 password: untuk login dengan email (di-hash bcrypt)
  //    Kalau login via Google/GitHub, password = null

  role String @default("admin")
  // 👆 role: "admin" atau "investor"
  //    admin  = akses penuh ke dashboard
  //    investor = akses terbatas ke portal investor

  accounts Account[]
  sessions Session[]
}

// ============================================
// LEAD — data dari form kontak
// ============================================

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  service   String
  message   String
  status    String   @default("new")
  // 👆 status: "new", "contacted", "qualified", "closed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PROJECT — portofolio proyek
// ============================================

model Project {
  id          String   @id @default(cuid())
  icon        String   @default("🌾")
  tag         String
  title       String
  description String
  location    String
  year        String
  metric      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// TESTIMONIAL — ulasan klien
// ============================================

model Testimonial {
  id      String @id @default(cuid())
  name    String
  role    String
  quote   String
  badge   String @default("farmer")
  // 👆 badge: "farmer", "government", "investor"
  stars   Int    @default(5)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
}
